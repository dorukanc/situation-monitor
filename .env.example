# GitHub Personal Access Token (optional — required for private repo commit tracking)
# Create one at: https://github.com/settings/tokens
# Scopes needed: repo (for private repo events), or just public_repo for public only
GITHUB_TOKEN=

# Your GitHub username (used to fetch commit activity)
NEXT_PUBLIC_GITHUB_USERNAME=

# Spotify Integration (optional — for music player widget)
# Create an app at: https://developer.spotify.com/dashboard
# Set redirect URI to: http://127.0.0.1:3000/api/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google OAuth (optional — for YouTube Music widget)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Set redirect URI to: http://127.0.0.1:3000/api/ytmusic/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
